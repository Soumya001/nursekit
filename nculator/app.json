{
  "expo": {
    "name": "Nculator",
    "slug": "nculator",
    "owner": "monga001s-team",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nculator.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0d"
      },
      "package": "com.nculator.app",
      "versionCode": 1
    },
    "plugins": [
      "./plugins/withKotlinVersion",
      [
        "expo-build-properties",
        {
          "android": { "compileSdkVersion": 35, "targetSdkVersion": 35, "kotlinVersion": "1.9.25" }
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "ae6177de-db97-4acd-b68b-352df55c2720" }
    }
  }
}
